@base <http://example.com/ns#>.
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix map:    <https://w3id.org/edint/cubo-turismo/mapping/> .

map:person_000 rdf:type foaf:Person ;
    rdfs:label "Diego Conde Herreros" .

map:rules_000 schema:contributor map:person_000 ;
    rdf:type schema:Dataset ;
    schema:version "0.1.0" ;
    schema:title "Ontología de Cubo de Datos Turísticos (Tourism Data Cubes Ontology)" ;
    schema:dateCreated "23-04-2026" ;
    schema:description "Este recurso define la ontología EDINT para cubos de datos turísticos, describiendo las estructuras de cubos de ocupación turística, flujo turístico e indicadores turísticos. La ontología reutiliza el vocabulario W3C RDF Data Cube y genera estructuras para especificar dimensiones y medidas. Incluye, entre otras, dimensiones como periodo, región administrativa, país de origen, tipo de flujo y número de registro del establecimiento, así como medidas como estancia media, grado de ocupación, crecimiento de plazas, intensidad por residente, número de turistas, plazas disponibles, viajeros, plazas ocupadas y pernoctaciones." .

<mappings_tourism_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "../pathtodata.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/def/actividad-economica/cubo-empleo/o{Indice}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant qb:Observation;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintdimension:refAdminRegion;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Area";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintdimension:refPeriod;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Periodo";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintdimension:countryOfOrigin;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Pais de Origen";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintdimension:flowType;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Tipo de Flujo Turístico";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintdimension:registrationNumber;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Número de Registro";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant qb:dataSet;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant edinttur:SampleDataSet;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:averageStay;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Estancia Media";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:degreeOccupation;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Grado de Ocupación";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:growthOfPlaces;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Tasa de Crecimiento";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:intensityPerResident;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Tasa de Intensidad por Residente";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:availablePlaces;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Plazas disponibles";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:numTravelers;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Número de Viajeros";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:occupiedPlaces;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Número de Plazas Ocupadas";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant edintmeasure:overnightStays;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "Número de Estancias¡";
		];
	].


