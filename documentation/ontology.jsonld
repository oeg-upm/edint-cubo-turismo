  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/measure#numTravelers",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3.org/TR/vocab-data-cube/MeasureProperty"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Number of travelers in general. May be tourism or business travelers."
  }, {
    "@language" : "es",
    "@value" : "Número de viajeros en general. Pueden ser viajeros de turismo o negocios."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "number of travelers"
  }, {
    "@language" : "es",
    "@value" : "número de viajeros"
  } ],
