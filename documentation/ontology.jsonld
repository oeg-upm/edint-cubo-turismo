  "http://purl.org/dc/terms/description" : [ {
    "@language" : "es",
    "@value" : "La ontología de Cubo de Datos Turísticos describe la estructura de los datos de ocupación turística, flujo turístico e indicadores en un único DSD que reúne todas las dimensiones y medidas."
  }, {
    "@language" : "en",
    "@value" : "The Tourism Data Cube ontology describes the structure of tourist occupancy, tourist flow and indicator data in a single DSD that gathers all dimensions and measures."
  } ],
