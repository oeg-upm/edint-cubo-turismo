  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/measure#averageStay",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3.org/TR/vocab-data-cube/MeasureProperty"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Average number of overnight stays. Measures the total number of overnight stays divided by the total number of tourists."
  }, {
    "@language" : "es",
    "@value" : "Número de pernoctas en promedio. Mide el número total de pernoctas entre el número total de turistas."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "average stay"
  }, {
    "@language" : "es",
    "@value" : "estancia media"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/linked-data/sdmx/2009/measure#obsValue"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3.org/TR/vocab-data-cube/MeasureProperty"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Grado de uso del alojamiento que permite detectar períodos de alta ocupación turística. Mide el total de plazas ocupadas sobre el total de plazas disponibles en un determinado período."
  }, {
    "@language" : "en",
    "@value" : "Occupancy rate, which allows for the detection of peak tourist periods. It measures the total number of occupied beds relative to the total number of available beds during a given period."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "grado de ocupación"
  }, {
    "@language" : "en",
    "@value" : "occupancy rate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/linked-data/sdmx/2009/measure#obsValue"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/measure#growthOfPlaces",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3.org/TR/vocab-data-cube/MeasureProperty"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Evolución de la capacidad alojativa en un período dado permitiendo conocer si está en expansión, estabilidad o recucción. Mide la variación porcentual de la capacidad alojativa de un período con respecto al período anterior."
  }, {
    "@language" : "en",
    "@value" : "The evolution of accommodation capacity over a given period allows us to determine if it is expanding, stable, or declining. It measures the percentage change in accommodation capacity in a certain period with respect to the previous period."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "crecimiento de plazas"
  }, {
    "@language" : "en",
    "@value" : "growth of places"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/linked-data/sdmx/2009/measure#obsValue"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/measure#intensityPerResident",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3.org/TR/vocab-data-cube/MeasureProperty"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Presión turística en un área determinada. Mide la relación entre el número de visitantes y el número de residentes en la zona."
  }, {
    "@language" : "en",
    "@value" : "Tourist pressure in a given area. It measures the relationship between the number of visitors and the number of residents in the area."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "intensidad por residente"
  }, {
    "@language" : "en",
    "@value" : "intensity per resident"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/linked-data/sdmx/2009/measure#obsValue"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/measure#numTourists",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3.org/TR/vocab-data-cube/MeasureProperty"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Número total de turistas que entran, salen o internos."
  }, {
    "@language" : "en",
    "@value" : "Total number of inbound, outbound or domestic tourists."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
