#################################################################
#    Annotations
#################################################################

<http://vocab.linkeddata.es/datosabiertos/def/dimension#countryOfResidence> rdfs:comment "Country of residence of the tourist."@en ,
                                                                                         "País de residencia del turista."@es ;
                                                                            rdfs:label "country of residence"@en ,
                                                                                       "país de residencia"@es ;
                                                                            :codeList <http://vocab.linkeddata.es/datosabiertos/kos/edint/country> .


<http://vocab.linkeddata.es/datosabiertos/def/dimension#flowType> rdfs:comment "Tipo de flujo turístico (nacional, internacional, interprovincial)."@es ,
                                                                               "Type of tourist flow (national, international, interprovintial)."@en ;
                                                                  rdfs:label "flow type"@en ,
                                                                             "tipo de flujo"@es ;
                                                                  :codeList <http://vocab.linkeddata.es/datosabiertos/kos/edint/TourismFlowType> .


<http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion> rdfs:comment "Reference to an administrative region that can be a neighborhood, district, or municipality."@en ,
                                                                                     "Referencia a una región administrativa que puede ser un barrio, distrito o municipio."@es ;
                                                                        rdfs:label "reference administrative region"@en ,
                                                                                   "región administrativa de referencia"@es .


<http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod> rdfs:comment "Intervalo de tiempo que puede ser por ejemplo una semana, un mes, un año."@es ,
                                                                                "Time interval that can be, for example, a week, a month, a year."@en ;
                                                                   rdfs:label "período de referencia"@es ,
                                                                              "reference period"@en .


<http://vocab.linkeddata.es/datosabiertos/def/dimension#registrationNumber> rdfs:comment "Número de registro del establecimiento turístico según Segittur."@es ,
                                                                                         "Tourist accommodation registration number as defined by Segittur."@en ;
                                                                            rdfs:label "número de registro (Segittur)"@es ,
                                                                                       "registration number (Segittur)"@en .


<http://vocab.linkeddata.es/datosabiertos/def/measure#availablePlaces> rdfs:comment "Beda available in Accomodations"@en ,
                                                                                    "Plazas disponibles en alojamientos."@es ;
                                                                       rdfs:label "available places"@en ,
                                                                                  "plazas disponibles"@es .


<http://vocab.linkeddata.es/datosabiertos/def/measure#averageStay> rdfs:comment "Average number of overnight stays. Measures the total number of overnight stays divided by the total number of tourists."@en ,
                                                                                "Número de pernoctas en promedio. Mide el número total de pernoctas entre el número total de turistas."@es ;
                                                                   rdfs:label "average stay"@en ,
                                                                              "estancia media"@es .


<http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation> rdfs:comment "Grado de uso del alojamiento que permite detectar períodos de alta ocupación turística. Mide el total de plazas ocupadas sobre el total de plazas disponibles en un determinado período."@es ,
                                                                                     "Occupancy rate, which allows for the detection of peak tourist periods. It measures the total number of occupied beds relative to the total number of available beds during a given period."@en ;
                                                                        rdfs:label "grado de ocupación"@es ,
                                                                                   "occupancy rate"@en .


<http://vocab.linkeddata.es/datosabiertos/def/measure#growthOfPlaces> rdfs:comment "Evolución de la capacidad alojativa en un período dado permitiendo conocer si está en expansión, estabilidad o recucción. Mide la variación porcentual de la capacidad alojativa de un período con respecto al período anterior."@es ,
                                                                                   "The evolution of accommodation capacity over a given period allows us to determine if it is expanding, stable, or declining. It measures the percentage change in accommodation capacity in a certain period with respect to the previous period."@en ;
                                                                      rdfs:label "crecimiento de plazas"@es ,
                                                                                 "growth of places"@en .


<http://vocab.linkeddata.es/datosabiertos/def/measure#intensityPerResident> rdfs:comment "Presión turística en un área determinada. Mide la relación entre el número de visitantes y el número de residentes en la zona."@es ,
                                                                                         "Tourist pressure in a given area. It measures the relationship between the number of visitors and the number of residents in the area."@en ;
                                                                            rdfs:label "intensidad por residente"@es ,
                                                                                       "intensity per resident"@en .


<http://vocab.linkeddata.es/datosabiertos/def/measure#numTourists> rdfs:comment "Número total de turistas que entran, salen o internos."@es ,
                                                                                "Total number of inbound, outbound or domestic tourists."@en ;
                                                                   rdfs:label "number of tourists"@en ,
                                                                              "número de turistas"@es .


<http://vocab.linkeddata.es/datosabiertos/def/measure#numTravelers> rdfs:comment "Number of travelers in general. May be tourism or business travelers."@en ,
                                                                                 "Número de viajeros en general. Pueden ser viajeros de turismo o negocios."@es ;
                                                                    rdfs:label "number of travelers"@en ,
                                                                               "número de viajeros"@es .


<http://vocab.linkeddata.es/datosabiertos/def/measure#occupiedPlaces> rdfs:comment "Número total de plazas que se han ocupado."@es ,
                                                                                   "Total number of places that have been occupied."@en ;
                                                                      rdfs:label "occupied places"@en ,
                                                                                 "plazas ocupadas"@es .


<http://vocab.linkeddata.es/datosabiertos/def/measure#overnightStays> rdfs:comment "Número total de pernoctas."@es ,
                                                                                   "Total number of overnight stays."@en ;
                                                                      rdfs:label "overnight stays"@en ,
                                                                                 "pernoctaciones"@es .


