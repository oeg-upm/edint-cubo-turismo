    <!-- http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#DSD_Tourism -->


    <owl:NamedIndividual rdf:about="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#DSD_Tourism">
        <rdf:type rdf:resource="https://www.w3.org/TR/vocab-data-cube/DataStructureDefinition"/>
        <rdfs:comment xml:lang="es">Estructura de datos integrada que combina las dimensiones y medidas de los cubos de ocupación turística, flujo turístico e indicadores turísticos.</rdfs:comment>
        <rdfs:label xml:lang="es">DSD integrado de turismo</rdfs:label>
        <rdfs:label xml:lang="en">Integrated tourism DSD</rdfs:label>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#growthOfPlaces"/>
            </rdf:Description>
        </component>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation"/>
            </rdf:Description>
        </component>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#intensityPerResident"/>
            </rdf:Description>
        </component>
        <component rdf:nodeID="genid8"/>
        <component rdf:nodeID="genid9"/>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#averageStay"/>
            </rdf:Description>
        </component>
        <component rdf:nodeID="genid11"/>
        <component rdf:nodeID="genid12"/>
        <component rdf:nodeID="genid13"/>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#numTravelers"/>
            </rdf:Description>
        </component>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#occupiedPlaces"/>
            </rdf:Description>
        </component>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#overnightStays"/>
            </rdf:Description>
        </component>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#numTourists"/>
            </rdf:Description>
        </component>
        <component>
            <rdf:Description>
                <measure rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/measure#availablePlaces"/>
            </rdf:Description>
        </component>
    </owl:NamedIndividual>
    <rdf:Description rdf:nodeID="genid8">
        <dimension rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/dimension#flowType"/>
        <order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</order>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid9">
        <dimension rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/dimension#countryOfResidence"/>
        <order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</order>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid11">
        <dimension rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/dimension#registrationNumber"/>
        <order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</order>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid12">
        <dimension rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod"/>
        <order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</order>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid13">
        <dimension rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion"/>
