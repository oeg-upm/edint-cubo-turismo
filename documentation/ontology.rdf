    <!-- http://purl.org/linked-data/sdmx/2009/dimension#refArea -->


    <owl:ObjectProperty rdf:about="http://purl.org/linked-data/sdmx/2009/dimension#refArea"/>
    


    <!-- http://purl.org/linked-data/sdmx/2009/dimension#refPeriod -->


    <owl:ObjectProperty rdf:about="http://purl.org/linked-data/sdmx/2009/dimension#refPeriod"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/dimension#countryOfResidence -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#countryOfResidence">
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/dimension#flowType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#flowType">
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/linked-data/sdmx/2009/dimension#refArea"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/linked-data/sdmx/2009/dimension#refPeriod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
    </owl:ObjectProperty>
    


