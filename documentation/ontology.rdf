<?xml version="1.0"?>
<rdf:RDF xmlns="https://www.w3.org/TR/vocab-data-cube/"
     xml:base="https://www.w3.org/TR/vocab-data-cube/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:vocab-data-cube="https://www.w3.org/TR/vocab-data-cube/">
    <owl:Ontology rdf:about="https://www.w3.org/TR/vocab-data-cube/">
        <owl:imports rdf:resource="https://www.w3.org/TR/vocab-data-cube/"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</terms:created>
        <terms:creator>Daniel Doña</terms:creator>
        <terms:creator>Diego Conde Herreros</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Oscar Corcho</terms:creator>
        <terms:creator>Socorro Bernardos</terms:creator>
        <terms:description xml:lang="es">La ontología de Cubo de Datos Turísticos describe la estructura de los datos de ocupación turística, flujo turístico e indicadores en un único DSD que reúne todas las dimensiones y medidas.</terms:description>
        <terms:description xml:lang="en">The Tourism Data Cube ontology describes the structure of tourist occupancy, tourist flow and indicator data in a single DSD that gathers all dimensions and measures.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="es">Ontología de Cubo de Datos Turísticos</terms:title>
        <terms:title xml:lang="en">Tourism Data Cube Ontology</terms:title>
        <vann:preferredNamespacePrefix>edinttur</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#"/>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


