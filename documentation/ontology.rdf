    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation">
