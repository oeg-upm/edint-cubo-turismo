    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio">
        <rdfs:comment xml:lang="en">A neighborhood is each of the parts into which large towns or their districts are divided [source: DRAE 2011].</rdfs:comment>
        <rdfs:comment xml:lang="es">Un barrio es cada una de las partes en que se dividen los pueblos grandes o sus distritos [fuente: DRAE 2011].</rdfs:comment>
        <rdfs:label xml:lang="es">Barrio</rdfs:label>
        <rdfs:label xml:lang="en">Neighbourhood</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito">
        <rdfs:comment xml:lang="es">Un distrito es cada una de las demarcaciones en que se subdivide un territorio o una población para distribuir y ordenar el ejercicio de los derechos civiles y políticos [fuente: DRAE 2011].</rdfs:comment>
        <rdfs:label xml:lang="en">District</rdfs:label>
        <rdfs:label xml:lang="es">Distrito</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio">
        <rdfs:comment xml:lang="es">Ente local definido en el artículo 140 de la Constitución española y entidad básica de la organización territorial del Estado según el artículo 1 de la Ley 7/1985.</rdfs:comment>
        <rdfs:label xml:lang="en">Municipality</rdfs:label>
        <rdfs:label xml:lang="es">Municipio</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


