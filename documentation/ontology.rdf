    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refAdminRegion">
        <rdfs:comment xml:lang="en">Reference to an administrative region that can be a neighborhood, district, or municipality.</rdfs:comment>
        <rdfs:comment xml:lang="es">Referencia a una región administrativa que puede ser un barrio, distrito o municipio.</rdfs:comment>
        <rdfs:label xml:lang="en">reference administrative region</rdfs:label>
        <rdfs:label xml:lang="es">región administrativa de referencia</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod">
        <rdfs:comment xml:lang="es">Intervalo de tiempo que puede ser por ejemplo una semana, un mes, un año.</rdfs:comment>
        <rdfs:comment xml:lang="en">Time interval that can be, for example, a week, a month, a year.</rdfs:comment>
        <rdfs:label xml:lang="es">período de referencia</rdfs:label>
        <rdfs:label xml:lang="en">reference period</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#registrationNumber">
        <rdfs:comment xml:lang="es">Número de registro del establecimiento turístico según Segittur.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourist accommodation registration number as defined by Segittur.</rdfs:comment>
        <rdfs:label xml:lang="es">número de registro (Segittur)</rdfs:label>
        <rdfs:label xml:lang="en">registration number (Segittur)</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#availablePlaces">
        <rdfs:comment xml:lang="en">Beda available in Accomodations</rdfs:comment>
        <rdfs:comment xml:lang="es">Plazas disponibles en alojamientos.</rdfs:comment>
        <rdfs:label xml:lang="en">available places</rdfs:label>
        <rdfs:label xml:lang="es">plazas disponibles</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#averageStay">
        <rdfs:comment xml:lang="en">Average number of overnight stays. Measures the total number of overnight stays divided by the total number of tourists.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de pernoctas en promedio. Mide el número total de pernoctas entre el número total de turistas.</rdfs:comment>
        <rdfs:label xml:lang="en">average stay</rdfs:label>
        <rdfs:label xml:lang="es">estancia media</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#degreeOccupation">
        <rdfs:comment xml:lang="es">Grado de uso del alojamiento que permite detectar períodos de alta ocupación turística. Mide el total de plazas ocupadas sobre el total de plazas disponibles en un determinado período.</rdfs:comment>
        <rdfs:comment xml:lang="en">Occupancy rate, which allows for the detection of peak tourist periods. It measures the total number of occupied beds relative to the total number of available beds during a given period.</rdfs:comment>
        <rdfs:label xml:lang="es">grado de ocupación</rdfs:label>
        <rdfs:label xml:lang="en">occupancy rate</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#growthOfPlaces">
        <rdfs:comment xml:lang="es">Evolución de la capacidad alojativa en un período dado permitiendo conocer si está en expansión, estabilidad o recucción. Mide la variación porcentual de la capacidad alojativa de un período con respecto al período anterior.</rdfs:comment>
        <rdfs:comment xml:lang="en">The evolution of accommodation capacity over a given period allows us to determine if it is expanding, stable, or declining. It measures the percentage change in accommodation capacity in a certain period with respect to the previous period.</rdfs:comment>
        <rdfs:label xml:lang="es">crecimiento de plazas</rdfs:label>
        <rdfs:label xml:lang="en">growth of places</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#intensityPerResident">
        <rdfs:comment xml:lang="es">Presión turística en un área determinada. Mide la relación entre el número de visitantes y el número de residentes en la zona.</rdfs:comment>
        <rdfs:comment xml:lang="en">Tourist pressure in a given area. It measures the relationship between the number of visitors and the number of residents in the area.</rdfs:comment>
        <rdfs:label xml:lang="es">intensidad por residente</rdfs:label>
        <rdfs:label xml:lang="en">intensity per resident</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#numTourists">
        <rdfs:comment xml:lang="es">Número total de turistas que entran, salen o internos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Total number of inbound, outbound or domestic tourists.</rdfs:comment>
        <rdfs:label xml:lang="en">number of tourists</rdfs:label>
        <rdfs:label xml:lang="es">número de turistas</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#numTravelers">
        <rdfs:comment xml:lang="en">Number of travelers in general. May be tourism or business travelers.</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de viajeros en general. Pueden ser viajeros de turismo o negocios.</rdfs:comment>
        <rdfs:label xml:lang="en">number of travelers</rdfs:label>
        <rdfs:label xml:lang="es">número de viajeros</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#occupiedPlaces">
        <rdfs:comment xml:lang="es">Número total de plazas que se han ocupado.</rdfs:comment>
        <rdfs:comment xml:lang="en">Total number of places that have been occupied.</rdfs:comment>
        <rdfs:label xml:lang="en">occupied places</rdfs:label>
        <rdfs:label xml:lang="es">plazas ocupadas</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/measure#overnightStays">
        <rdfs:comment xml:lang="es">Número total de pernoctas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Total number of overnight stays.</rdfs:comment>
        <rdfs:label xml:lang="en">overnight stays</rdfs:label>
        <rdfs:label xml:lang="es">pernoctaciones</rdfs:label>
    </rdf:Description>
</rdf:RDF>



