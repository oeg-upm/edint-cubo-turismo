#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:CountryOfResidence a skos:ConceptScheme ; 
    dct:issued "2026-04-24"^^xsd:date ;
    dct:modified "2026-04-24"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Country of residence"@en ;
    rdfs:label "País de residencia"@es ;
    dct:title "Concept scheme grouping countries according to ISO 3166-1 alpha-2 and ISO 3166-1 alpha-3 notation"@en ;
    dct:title "Esquema de conceptos que agrupa países según notación ISO 3166-1 alfa-2 e ISO 3166-1 alfa-3"@es .

	
#################################################################
#
#    Data type instances
#
#################################################################

edintkoscoures:iso3166-1-alpha-2DT
	a rdfs:Datatype.

edintkoscoures:iso3166-1-alpha-3DT
	a rdfs:Datatype.


#################################################################
#
