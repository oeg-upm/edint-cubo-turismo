    <!-- http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#refAdminRegion -->

    <owl:AnnotationProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#refAdminRegion">
