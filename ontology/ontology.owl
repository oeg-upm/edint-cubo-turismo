    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/linked-data/cube#codeList -->

    <owl:ObjectProperty rdf:about="http://purl.org/linked-data/cube#codeList">
        <rdfs:domain rdf:resource="http://purl.org/linked-data/cube#CodedProperty"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/linked-data/cube#HierarchicalCodeList"/>
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Collection"/>
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">gives the code list associated with a CodedProperty</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/linked-data/cube"/>
        <rdfs:label xml:lang="en">code list</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/linked-data/cube#component -->

    <owl:ObjectProperty rdf:about="http://purl.org/linked-data/cube#component">
        <rdfs:domain rdf:resource="http://purl.org/linked-data/cube#DataStructureDefinition"/>
        <rdfs:range rdf:resource="http://purl.org/linked-data/cube#ComponentSpecification"/>
        <rdfs:comment xml:lang="en">Indicates a component specification which is included in the structure of the dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/linked-data/cube#dimension -->

    <owl:ObjectProperty rdf:about="http://purl.org/linked-data/cube#dimension">
        <rdfs:range rdf:resource="http://purl.org/linked-data/cube#DimensionProperty"/>
        <rdfs:comment xml:lang="en">An alternative to qb:componentProperty which makes explicit that the component is a dimension.</rdfs:comment>
        <rdfs:label xml:lang="en">dimension</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/linked-data/cube#measure -->

    <owl:ObjectProperty rdf:about="http://purl.org/linked-data/cube#measure">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:range rdf:resource="http://purl.org/linked-data/cube#MeasureProperty"/>
        <rdfs:comment xml:lang="en">An alternative to qb:componentProperty which makes explicit that the component is a measure.</rdfs:comment>
        <rdfs:label xml:lang="en">measure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/dimension#refPeriod">
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#barrio -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#barrio">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#sfWithin"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2014-03-28</dcterms:issued>
        <rdfs:comment xml:lang="es">Barrio al que pertenece un fenómeno geográfico o una entidad administrativa</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">pertenece al barrio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#distrito -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#distrito">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#sfWithin"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2014-03-28</dcterms:issued>
        <rdfs:comment xml:lang="es">Distrito al que pertenece un fenómeno geográfico o una entidad administrativa</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">pertenece al distrito</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#sfWithin"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2014-03-28</dcterms:issued>
        <rdfs:comment xml:lang="es">Municipio al que pertenece un fenómeno geográfico o una entidad administrativa</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">pertenece al municipio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#provincia -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#provincia"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#refAdminRegion -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#refAdminRegion">
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.geonames.org/ontology#featureClass -->

    <owl:ObjectProperty rdf:about="http://www.geonames.org/ontology#featureClass"/>
    


    <!-- http://www.geonames.org/ontology#featureCode -->

    <owl:ObjectProperty rdf:about="http://www.geonames.org/ontology#featureCode"/>
    


    <!-- http://www.opengis.net/ont/geosparql#sfWithin -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#sfWithin"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2006/time#hasXSDDuration -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#hasXSDDuration">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <rdfs:comment xml:lang="es">Extensión de una entidad temporal, expresada utilizando xsd:duration.</rdfs:comment>
        <rdfs:comment xml:lang="en">Extent of a temporal entity, expressed using xsd:duration</rdfs:comment>
        <rdfs:label xml:lang="en">has XSD duration</rdfs:label>
        <rdfs:label xml:lang="es">tiene duración XSD</rdfs:label>
        <skos:definition xml:lang="es">Extensión de una entidad temporal, expresada utilizando xsd:duration.</skos:definition>
        <skos:definition xml:lang="en">Extent of a temporal entity, expressed using xsd:duration</skos:definition>
        <skos:editorialNote xml:lang="es">Característica arriesgada - añadida en la revisión de 2017, y todavía no ampliamente utilizada.</skos:editorialNote>
        <skos:editorialNote xml:lang="en">Feature at risk - added in 2017 revision, and not yet widely used.</skos:editorialNote>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDDateTimeStamp -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDDateTimeStamp">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="es">Posición de un instante, expresado utilizando xsd:dateTimeStamp.</rdfs:comment>
        <rdfs:comment xml:lang="en">Position of an instant, expressed using xsd:dateTimeStamp</rdfs:comment>
        <rdfs:label xml:lang="es">en fecha-sello de tiempo XSD</rdfs:label>
        <rdfs:label xml:lang="en">in XSD Date-Time-Stamp</rdfs:label>
        <skos:definition xml:lang="es">Posición de un instante, expresado utilizando xsd:dateTimeStamp.</skos:definition>
        <skos:definition xml:lang="en">Position of an instant, expressed using xsd:dateTimeStamp</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDgYearMonth -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDgYearMonth">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYearMonth"/>
        <rdfs:comment xml:lang="es">Posición de un instante, expresado utilizando xsd:gYearMonth.</rdfs:comment>
        <rdfs:comment xml:lang="en">Position of an instant, expressed using xsd:gYearMonth</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2006/time#"/>
        <rdfs:label xml:lang="es">en año-mes gregoriano XSD</rdfs:label>
        <rdfs:label xml:lang="en">in XSD g-YearMonth</rdfs:label>
        <skos:definition xml:lang="es">Posición de un instante, expresado utilizando xsd:gYearMonth.</skos:definition>
        <skos:definition xml:lang="en">Position of an instant, expressed using xsd:gYearMonth</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://datos.ign.es/def/geo_core#xETRS89 -->

    <owl:DatatypeProperty rdf:about="https://datos.ign.es/def/geo_core#xETRS89">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:source xml:lang="es">Catálogo de Objetos Geográficos BTN100.</dc:source>
        <rdfs:comment xml:lang="es">Coordenada X en metros (ETRS89)</rdfs:comment>
        <rdfs:comment xml:lang="en">X-Coordinate in meters (ETRS89)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://datos.ign.es/def/geo_core#"/>
        <rdfs:label>xETRS89</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://datos.ign.es/def/geo_core#yETRS89 -->

    <owl:DatatypeProperty rdf:about="https://datos.ign.es/def/geo_core#yETRS89">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:source xml:lang="es">Catálogo de Objetos Geográficos BTN100.</dc:source>
        <rdfs:comment xml:lang="es">Coordenada Y en metros (ETRS89)</rdfs:comment>
        <rdfs:comment xml:lang="en">Y-Coordinate in meters (ETRS89)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://datos.ign.es/def/geo_core#"/>
        <rdfs:label>yETRS89</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dbpedia.org/ontology/District -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/District"/>
    


    <!-- http://dbpedia.org/ontology/Municipality -->

    <owl:Class rdf:about="http://dbpedia.org/ontology/Municipality"/>
    


    <!-- http://purl.org/linked-data/cube#AttributeProperty -->

    <owl:Class rdf:about="http://purl.org/linked-data/cube#AttributeProperty">
        <rdfs:subClassOf rdf:resource="http://purl.org/linked-data/cube#ComponentProperty"/>
        <owl:disjointWith rdf:resource="http://purl.org/linked-data/cube#MeasureProperty"/>
        <rdfs:comment xml:lang="en">An alternative to qb:componentProperty which makes explicit that the component is a attribute.</rdfs:comment>
        <rdfs:label xml:lang="en">Attribute property</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/linked-data/cube#CodedProperty -->

    <owl:Class rdf:about="http://purl.org/linked-data/cube#CodedProperty">
        <rdfs:subClassOf rdf:resource="http://purl.org/linked-data/cube#ComponentProperty"/>
        <rdfs:comment xml:lang="en">Gives the code list associated with a CodedProperty.</rdfs:comment>
        <rdfs:label xml:lang="en">Coded property</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/linked-data/cube#ComponentProperty -->

    <owl:Class rdf:about="http://purl.org/linked-data/cube#ComponentProperty">
        <rdfs:comment xml:lang="en">Indicates a ComponentProperty (i.e. attribute/dimension) expected on a DataSet, or a dimension fixed in a SliceKey.</rdfs:comment>
        <rdfs:label xml:lang="en">Component property</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/linked-data/cube#ComponentSet -->

    <owl:Class rdf:about="http://purl.org/linked-data/cube#ComponentSet">
        <rdfs:comment xml:lang="en">Abstract class of things which reference one or more ComponentProperties.</rdfs:comment>
        <rdfs:label xml:lang="en">Component set</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/linked-data/cube#ComponentSpecification -->

