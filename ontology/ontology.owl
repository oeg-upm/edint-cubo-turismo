<?xml version="1.0"?>
<rdf:RDF xmlns="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#"
     xml:base="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:qb="http://purl.org/linked-data/cube#"
     xmlns:gsp="http://www.opengis.net/ont/geosparql#"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:esadm="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#"
     xmlns:schema="http://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:edintkos="http://vocab.linkeddata.es/datosabiertos/kos/edint/"
     xmlns:segittur="https://ontologia.segittur.es/turismo/def/core#"
     xmlns:edintdimension="http://vocab.linkeddata.es/datosabiertos/def/dimension#"
     xmlns:sdmx-dimension="http://purl.org/linked-data/sdmx/2009/dimension#">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#"/>
        <dcterms:created>2026-04-17</dcterms:created>
        <dcterms:creator>Daniel Doña</dcterms:creator>
        <dcterms:creator>Diego Conde Herreros</dcterms:creator>
        <dcterms:creator>Edna Ruckhaus</dcterms:creator>
        <dcterms:creator>Lucía Sánchez</dcterms:creator>
        <dcterms:creator>Oscar Corcho</dcterms:creator>
        <dcterms:creator>Socorro Bernardos</dcterms:creator>
        <dcterms:description xml:lang="es">La ontología de Cubo de Datos Turísticos describe las estructuras de los  cubos de datos de ocupación turística, flujo turístico y de algunos indicadores. Para ello se reutiliza el vocabulario W3C Data Cube y se han generado instancias para cada estructura con la finalidad de indicar las dimensiones y medidas que se emplean en cada uno de los cubos.</dcterms:description>
        <dcterms:description xml:lang="en">The Tourism Data Cube ontology describes the structures of the data cubes for tourist occupancy, tourist flow, and some indicators. To do this, the W3C Data Cube vocabulary is reused, and instances have been generated for each structure to indicate the dimensions and measures used in each cube.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:title xml:lang="es">Ontología de Cubo de Datos Turísticos</dcterms:title>
        <dcterms:title xml:lang="en">Tourism Data Cubes Ontology</dcterms:title>
        <vann:preferredNamespacePrefix>edinttur</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/turismo/cubo-turismo#"/>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


